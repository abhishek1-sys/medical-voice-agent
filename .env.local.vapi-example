# ════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your actual API keys
# ════════════════════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════
# DATABASE
# ════════════════════════════════════════════════════════
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/medical_voice_db"

# ════════════════════════════════════════════════════════
# CLERK AUTHENTICATION
# Get from: https://clerk.com → Dashboard → API Keys
# ════════════════════════════════════════════════════════
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_YOUR_KEY_HERE"
CLERK_SECRET_KEY="sk_test_YOUR_KEY_HERE"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# ════════════════════════════════════════════════════════
# VAPI.AI - Voice Agent Platform (REQUIRED)
# Get from: https://vapi.ai → Dashboard → API Keys
# This handles: Voice recognition, Speech synthesis, Real-time conversation
# ════════════════════════════════════════════════════════
VAPI_API_KEY="your_vapi_private_key_here"
NEXT_PUBLIC_VAPI_PUBLIC_KEY="your_vapi_public_key_here"

# ════════════════════════════════════════════════════════
# GOOGLE GEMINI - AI Analysis (REQUIRED)
# Get from: https://ai.google.dev
# Used for: Medical analysis, Specialist suggestion
# ════════════════════════════════════════════════════════
GEMINI_API_KEY="your_gemini_api_key_here"

# ════════════════════════════════════════════════════════
# APP CONFIGURATION
# ════════════════════════════════════════════════════════
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ════════════════════════════════════════════════════════
# LEGACY (NO LONGER NEEDED - Vapi handles transcription)
# ════════════════════════════════════════════════════════
# ASSEMBLYAI_API_KEY="" # Not required anymore!
